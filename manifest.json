{
  "manifest_version": 3,
  "name": "Abdus Dashboard",
  "version": "1.1",
  "description": "A minimalist, premium new tab dashboard.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "topSites"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*"
      ],
      "js": ["ai-inject.js"],
      "run_at": "document_idle"
    }
  ]
}
