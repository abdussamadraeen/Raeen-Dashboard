{
  "manifest_version": 3,
  "name": "Abdus Dashboard Lite",
  "version": "1.2",
  "description": "A lightweight, premium new tab dashboard optimized for speed.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "topSites"
  ],
  "host_permissions": [
    "https://suggestqueries.google.com/*",
    "https://*.bing.com/*",
    "https://bing.biturl.top/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
